#!/bin/bash
#
# NanoHUB Bulk Install Profile Script
#
# Description:
# This script installs a specified profile to multiple devices.
# Devices can be specified as comma-separated UUIDs.
#
# Usage:
#   ./bulk_install_profile <device_uuids> <profile.mobileconfig>
#
# Parameters:
#   <device_uuids>         - Comma-separated list of device UUIDs
#   <profile.mobileconfig> - Path to the profile to be installed
#
# Example:
#   ./bulk_install_profile "uuid1,uuid2,uuid3" /path/to/profile.mobileconfig
#
# Requirements:
#   - Profile file must exist
#   - NanoMDM API running and accessible
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 <device_uuids> <profile.mobileconfig>"
  echo "  device_uuids: Comma-separated list of device UUIDs"
  exit 1
fi

DEVICES="$1"
PROFILE_PATH="$2"

if [ ! -f "$PROFILE_PATH" ]; then
  echo "Error: Profile file '$PROFILE_PATH' not found!"
  exit 1
fi

# Source environment variables
if [[ -f /home/microm/nanohub/environment.sh ]]; then
  source /home/microm/nanohub/environment.sh
fi

echo "Starting bulk profile installation"
echo "Using profile: $PROFILE_PATH"

# Convert comma-separated list to array
IFS=',' read -ra DEVICE_ARRAY <<< "$DEVICES"

DEVICE_COUNT=${#DEVICE_ARRAY[@]}
echo "Target devices: $DEVICE_COUNT"
echo ""
echo "Starting parallel execution..."
echo ""

# Parallel execution - all commands run simultaneously
for UDID in "${DEVICE_ARRAY[@]}"; do
  # Trim whitespace
  UDID=$(echo "$UDID" | xargs)
  if [ -n "$UDID" ]; then
    echo "Installing profile on device: $UDID"
    "$SCRIPT_DIR/install_profile" "$UDID" "$PROFILE_PATH" &
  fi
done

# Wait for all background jobs to complete
wait

echo ""
echo "========================================="
echo "Bulk profile installation completed"
echo "Total devices: $DEVICE_COUNT"
echo "All commands sent in parallel"
echo "========================================="
