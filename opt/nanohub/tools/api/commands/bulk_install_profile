#!/bin/bash
#
# NanoHUB Bulk Install Profile Script
#
# Description:
# This script installs a specified profile to all devices listed in the data/devices.json file,
# filtered by the 'ios' or 'macos' operating system parameter.
#
# Usage:
#   ./bulk_install_profile.sh <ios|macos> <profile.mobileconfig>
#
# Parameters:
#   <ios|macos>            - Target OS for profile install
#   <profile.mobileconfig> - Path to the profile to be installed
#
# Example:
#   ./bulk_install_profile ios /path/to/ios_profile.mobileconfig
#   ./bulk_install_profile macos /path/to/macos_profile.mobileconfig
#
# Requirements:
#   - 'jq' JSON processor installed on system
#   - Profile file must exist
#   - NanoMDM API running and accessible
#

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 <ios|macos> <profile.mobileconfig>"
  exit 1
fi

TARGET_OS="$1"
PROFILE_PATH="$2"

if [ ! -f "$PROFILE_PATH" ]; then
  echo "Error: Profile file '$PROFILE_PATH' not found!"
  exit 1
fi

# Source environment variables for DB credentials
if [[ -f /opt/nanohub/environment.sh ]]; then
  source /opt/nanohub/environment.sh
else
  echo "Error: /opt/nanohub/environment.sh not found!"
  exit 1
fi

echo "Starting bulk profile installation for OS: $TARGET_OS"
echo "Using profile: $PROFILE_PATH"

# Extract device UUIDs matching the target OS using SQL
DEVICE_UUIDS=$(mysql -h "$DB_HOST" -u "$DB_USER" -p"$DB_PASSWORD" "$DB_NAME" -sN -e "SELECT uuid FROM device_inventory WHERE os='$TARGET_OS' ORDER BY hostname" 2>/dev/null)

if [ -z "$DEVICE_UUIDS" ]; then
  echo "No devices found for OS: $TARGET_OS"
  exit 0
fi

# Count devices
DEVICE_COUNT=$(echo "$DEVICE_UUIDS" | wc -l)
echo "Found $DEVICE_COUNT device(s)"
echo ""
echo "Starting parallel execution..."
echo ""

# Parallel execution - all commands run simultaneously
for UDID in $DEVICE_UUIDS; do
  echo "Installing profile on device UDID: $UDID"
  ./tools/api/commands/install_profile "$UDID" "$PROFILE_PATH" &
done

# Wait for all background jobs to complete
wait

echo ""
echo "========================================="
echo "Bulk profile installation completed"
echo "Total devices: $DEVICE_COUNT"
echo "All commands sent in parallel"
echo "========================================="
