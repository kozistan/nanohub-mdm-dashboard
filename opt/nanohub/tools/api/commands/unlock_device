#!/bin/bash
# device_unlock.sh - Unlock device using PIN or UnlockToken
# Usage: ./device_unlock.sh <UDID> [PIN]

if [ $# -lt 1 ]; then
    echo "Usage: $0 <UDID> [PIN]"
    echo "Example: $0 00008020-0001713C1E90003A"
    echo "Example: $0 00008020-0001713C1E90003A 123456"
    echo ""
    echo "Note: If no PIN provided, uses UnlockToken from enrollment"
    exit 1
fi

UDID="$1"
PIN="$2"

CMD_UUID=$(uuidgen)

# Vytvoř DeviceUnlock command (unique temp file for parallel execution)
TEMP_PLIST="/tmp/cmd_${UDID}_$$.plist"
if [ -n "$PIN" ]; then
    # Unlock s PIN
    cat > "$TEMP_PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Command</key>
    <dict>
        <key>RequestType</key>
        <string>DeviceUnlock</string>
        <key>PIN</key>
        <string>$PIN</string>
    </dict>
    <key>CommandUUID</key>
    <string>$CMD_UUID</string>
</dict>
</plist>
PLIST_EOF
    echo "Unlocking device with PIN: $PIN"
else
    # Unlock s UnlockToken (automatický)
    cat > "$TEMP_PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Command</key>
    <dict>
        <key>RequestType</key>
        <string>DeviceUnlock</string>
    </dict>
    <key>CommandUUID</key>
    <string>$CMD_UUID</string>
</dict>
</plist>
PLIST_EOF
    echo "Unlocking device with UnlockToken"
fi

echo "Device UDID: $UDID"
echo "Command UUID: $CMD_UUID"

RESPONSE=$(curl -s -T "$TEMP_PLIST" \
  -u "nanohub:ddce14cd1184371050150aaeaef30d65ae5441a3d5ccdf3099cd815f3bb5c774" \
  -w "HTTP_CODE:%{http_code}" \
  "http://localhost:9004/api/v1/nanomdm/enqueue/$UDID")

HTTP_CODE=$(echo "$RESPONSE" | grep -o "HTTP_CODE:[0-9]*" | cut -d: -f2)
BODY=$(echo "$RESPONSE" | sed 's/HTTP_CODE:[0-9]*$//')

rm -f "$TEMP_PLIST"

if [ "$HTTP_CODE" = "200" ]; then
    echo "Device unlock command sent successfully!"
else
    echo "Failed to send device unlock command (HTTP: $HTTP_CODE)"
    echo "Response: $BODY"
fi
