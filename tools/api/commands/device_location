#!/bin/bash
# Source environment
source /opt/nanohub/environment.sh
# NanoHUB DeviceLocation - request current location (Lost Mode only)
# Usage: ./device_location <UDID>
#
# NOTE: Apple returns a location ONLY for supervised iOS/iPadOS devices that are
# currently in Lost Mode (EnableLostMode). Otherwise the device answers Error/NotNow.
# The Acknowledged response (Latitude/Longitude/...) is stored by NanoMDM and
# parsed by the webhook into device_details.location_data.

if [ $# -ne 1 ]; then
    echo "Usage: $0 <UDID>"
    exit 1
fi

UDID="$1"
CMD_UUID=$(uuidgen)
TEMP_PLIST="/tmp/cmd_${UDID}_$$.plist"

cat > "$TEMP_PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Command</key>
    <dict>
        <key>RequestType</key>
        <string>DeviceLocation</string>
    </dict>
    <key>CommandUUID</key>
    <string>$CMD_UUID</string>
</dict>
</plist>
PLIST_EOF

echo "Requesting device location (Lost Mode): $UDID"
echo "Command UUID: $CMD_UUID"

RESPONSE=$(curl -s -T "$TEMP_PLIST" \
  -u "nanohub:${NANOHUB_API_KEY}" \
  -w "HTTP_CODE:%{http_code}" \
  "http://localhost:9004/api/v1/nanomdm/enqueue/$UDID")

HTTP_CODE=$(echo "$RESPONSE" | grep -o "HTTP_CODE:[0-9]*" | cut -d: -f2)
BODY=$(echo "$RESPONSE" | sed 's/HTTP_CODE:[0-9]*$//')

rm -f "$TEMP_PLIST"

if [ "$HTTP_CODE" = "200" ]; then
    echo "DeviceLocation command sent. Location will appear once the device checks in (requires active Lost Mode)."
else
    echo "Failed to send DeviceLocation command (HTTP: $HTTP_CODE)"
    echo "Response: $BODY"
    exit 1
fi
