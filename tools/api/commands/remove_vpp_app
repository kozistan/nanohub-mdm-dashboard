#!/bin/bash
# Source environment
source /opt/nanohub/environment.sh
# Removes a VPP app from device and unassigns the license - NanoHUB version
# Usage: ./unregister_remove_vpp_application <UDID> <ADAM_ID> <SERIAL> <BUNDLE_ID>
set -euo pipefail

if [ $# -ne 4 ]; then
    echo "Usage: $0 <UDID> <ADAM_ID> <SERIAL> <BUNDLE_ID>"
    echo "Example: $0 00008020-0001713C1E90003A 422689480 F4GXDDQRKXK2 com.google.Gmail"
    echo ""
    echo "ADAM_ID: iTunes Store ID"
    echo "SERIAL: Device serial number" 
    echo "BUNDLE_ID: App bundle identifier"
    exit 1
fi

UDID="$1"
ADAM_ID="$2"
SERIAL="$3"
BUNDLE_ID="$4"

# VPP Token - check environment or config
if [[ -z "${VPP_TOKEN:-}" ]]; then
    # Try to load from file
    if [ -f "/home/microm/nanohub/vpp/vpp_token.txt" ]; then
        VPP_TOKEN=$(cat /home/microm/nanohub/vpp/vpp_token.txt)
    else
        echo "[ERROR] VPP_TOKEN is not set."
        echo "Set environment variable: export VPP_TOKEN='your_token'"
        echo "Or create file: /home/microm/nanohub/vpp/vpp_token.txt"
        exit 1
    fi
fi

echo "[INFO] Unassigning VPP license for adamId=$ADAM_ID from serial=$SERIAL..."

# VPP License Disassociation Payload
VPP_PAYLOAD=$(jq -n \
  --arg adamId "$ADAM_ID" \
  --arg serial "$SERIAL" \
  '{
    assets: [ { adamId: $adamId } ],
    serialNumbers: [ $serial ]
  }')

# Disassociate VPP License
VPP_RESPONSE=$(curl -sS -X POST \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $VPP_TOKEN" \
  -d "$VPP_PAYLOAD" \
  https://vpp.itunes.apple.com/mdm/v2/assets/disassociate)

echo "VPP Disassociation Response:"
echo "$VPP_RESPONSE" | jq .

# Check for errors in VPP response
if echo "$VPP_RESPONSE" | jq -e '.errorMessage' > /dev/null; then
    echo "[WARNING] VPP License disassociation had issues:"
    echo "$VPP_RESPONSE" | jq .
    echo "Continuing with app removal..."
else
    echo "[OK] VPP license unassignment completed."
fi

echo "[INFO] Sending RemoveApplication command for $BUNDLE_ID to UDID=$UDID..."

# Generate command UUID
CMD_UUID=$(uuidgen)

# Create RemoveApplication command for NanoMDM (unique temp file for parallel execution)
TEMP_PLIST="/tmp/cmd_${UDID}_$$.plist"
cat > "$TEMP_PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Command</key>
    <dict>
        <key>RequestType</key>
        <string>RemoveApplication</string>
        <key>Identifier</key>
        <string>$BUNDLE_ID</string>
    </dict>
    <key>CommandUUID</key>
    <string>$CMD_UUID</string>
</dict>
</plist>
PLIST_EOF

echo "Removing VPP App:"
echo "  Device UDID: $UDID"
echo "  iTunes Store ID: $ADAM_ID"
echo "  Serial Number: $SERIAL"
echo "  Bundle ID: $BUNDLE_ID"
echo "  Command UUID: $CMD_UUID"

# Send RemoveApplication command to NanoMDM
RESPONSE=$(curl -s -T "$TEMP_PLIST" \
  -u "nanohub:${NANOHUB_API_KEY}" \
  -w "HTTP_CODE:%{http_code}" \
  "http://localhost:9004/api/v1/nanomdm/enqueue/$UDID")

HTTP_CODE=$(echo "$RESPONSE" | grep -o "HTTP_CODE:[0-9]*" | cut -d: -f2)
BODY=$(echo "$RESPONSE" | sed 's/HTTP_CODE:[0-9]*$//')

# Cleanup
rm -f "$TEMP_PLIST"

if [ "$HTTP_CODE" = "200" ]; then
    echo "[OK] VPP App removal command sent successfully!"
    echo "App should be removed from device and license returned to pool"
    echo "Response: $BODY"
else
    echo "[ERROR] Failed to send VPP app removal command (HTTP: $HTTP_CODE)"
    echo "Response: $BODY"
    exit 1
fi

echo ""
echo "[INFO] VPP Managed App removal complete!"
echo ""
echo "Monitor removal with:"
echo "tail -f /var/log/nanohub/webhook.log | grep -E '(RemoveApplication|app)'"
