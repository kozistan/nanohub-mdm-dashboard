#!/bin/bash
# Source environment
source /opt/nanohub/environment.sh
# NanoHUB DeviceInformation - Query device information
# Usage: ./device_information <UDID>

if [ $# -ne 1 ]; then
    echo "Usage: $0 <UDID>"
    exit 1
fi

UDID="$1"
CMD_UUID=$(uuidgen)
TEMP_PLIST="/tmp/cmd_${UDID}_$$.plist"

cat > "$TEMP_PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Command</key>
    <dict>
        <key>RequestType</key>
        <string>DeviceInformation</string>
        <key>Queries</key>
        <array>
            <string>UDID</string>
            <string>DeviceName</string>
            <string>OSVersion</string>
            <string>SerialNumber</string>
        </array>
    </dict>
    <key>CommandUUID</key>
    <string>$CMD_UUID</string>
</dict>
</plist>
PLIST_EOF

echo "Querying device information: $UDID"
echo "Command UUID: $CMD_UUID"

RESPONSE=$(curl -s -T "$TEMP_PLIST" \
  -u "nanohub:${NANOHUB_API_KEY}" \
  -w "HTTP_CODE:%{http_code}" \
  "http://localhost:9004/api/v1/nanomdm/enqueue/$UDID")

HTTP_CODE=$(echo "$RESPONSE" | grep -o "HTTP_CODE:[0-9]*" | cut -d: -f2)
BODY=$(echo "$RESPONSE" | sed 's/HTTP_CODE:[0-9]*$//')

rm -f "$TEMP_PLIST"

if [ "$HTTP_CODE" = "200" ]; then
    echo "DeviceInformation command sent successfully!"
else
    echo "Failed to send DeviceInformation command (HTTP: $HTTP_CODE)"
    echo "Response: $BODY"
    exit 1
fi
