#!/bin/bash

read -p "Enter UUID: " UUID

LOG_DIR="/var/log/nanohub"
LOG_PATTERN="webhook.log*"

FILES=$(ls -1 $LOG_DIR/$LOG_PATTERN | sort -t. -k2,2n)

declare -A TOPIC_STATS
declare -A DAYS_STATS

DAYS_COUNT=0
REPORT_FILE="/tmp/report_${UUID}.log"
> "$REPORT_FILE" # clear old content

for f in $FILES; do
    if [[ "$f" == *.gz ]]; then
        MATCHES=$(zgrep -A5 -B1 "udid: $UUID" "$f")
    else
        MATCHES=$(grep -A5 -B1 "udid: $UUID" "$f")
    fi

    if [[ -n "$MATCHES" ]]; then
        ((DAYS_COUNT++))
        echo "--- $(basename "$f") ---" >> "$REPORT_FILE"

        current_topic=""
        current_time=""
        while read -r line; do
            # timestamp
            if [[ "$line" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]][0-9]{2}:[0-9]{2}:[0-9]{2}) ]]; then
                current_time="${BASH_REMATCH[1]}"
            fi

            # topic
            if [[ "$line" =~ topic:[[:space:]]*(.*) ]]; then
                current_topic="${BASH_REMATCH[1]}"
                KEY="$(basename "$f")|$current_topic"
                ((TOPIC_STATS["$KEY"]++))
                ((DAYS_STATS["$current_topic"]++))
            fi

            # status -> uložíme komplet event
            if [[ "$line" =~ status:[[:space:]]*(.*) ]]; then
                echo "Time: $current_time" >> "$REPORT_FILE"
                echo "Topic: $current_topic" >> "$REPORT_FILE"
                echo "Status: ${BASH_REMATCH[1]}" >> "$REPORT_FILE"
                echo "------------------------" >> "$REPORT_FILE"
            fi
        done <<< "$MATCHES"
    fi
done

echo
echo "=== Topic Stats per Day for UUID: $UUID ==="
printf "%-20s %-20s %10s\n" "File(Day)" "Topic" "Hits"
echo "-------------------------------------------------------------"

for f in $FILES; do
    for t in $(printf "%s\n" "${!TOPIC_STATS[@]}" | grep "^$(basename "$f")|" | cut -d'|' -f2 | sort | uniq); do
        KEY="$(basename "$f")|$t"
        printf "%-20s %-20s %10d\n" "$(basename "$f")" "$t" "${TOPIC_STATS[$KEY]}"
    done
done

echo "-------------------------------------------------------------"
echo "UUID found in $DAYS_COUNT days ($(echo $FILES | wc -w) total log files)"

echo
echo "=== Total by Topic Across Days ==="
printf "%-20s %10s %s\n" "Topic" "Days" "Graph"
echo "-------------------------------------------------------------"
for t in "${!DAYS_STATS[@]}"; do
    GRAPH=$(printf "%0.s*" $(seq 1 ${DAYS_STATS[$t]}))
    printf "%-20s %10d %s\n" "$t" "${DAYS_STATS[$t]}" "$GRAPH"
done

# >>> POSLEDNÍ 3 KOMPLETNÍ EVENTY <<<
echo
read -p "Do you want to print last 3 events? [y/N]: " ANS
if [[ "$ANS" =~ ^[Yy]$ ]]; then
    echo
    echo "=== Last 3 Events (timestamp, topic & status) ==="
    awk -v RS="------------------------" '
        NF { blocks[++count] = $0 RS }
        END {
            for (i = (count-2 > 0 ? count-2 : 1); i <= count; i++)
                print blocks[i]
        }
    ' "$REPORT_FILE"
fi

echo
echo "Full report saved to: $REPORT_FILE"
