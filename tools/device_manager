#!/bin/bash
#
# NanoHUB Device Manager - CRUD Operations for device_inventory
#
# Description:
# Comprehensive tool for managing devices in the device_inventory SQL table
# Supports: Create, Read, Update, Delete operations
#
# Usage:
#   ./device_manager.sh <command> [options]
#
# Commands:
#   search <term>                     - Search by hostname, serial, UUID, or OS
#   get <field> <value>               - Get device by specific field
#   add                               - Add new device (interactive)
#   update <uuid>                     - Update device by UUID (interactive)
#   delete <uuid>                     - Delete device by UUID (with confirmation)
#   list [os]                         - List all devices or filter by OS
#   count [os]                        - Count devices (all or by OS)
#   export                            - Export all devices as JSON
#   import <json_file>                - Import devices from JSON file
#

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Source environment variables
if [[ -f /home/microm/nanohub/environment.sh ]]; then
  source /home/microm/nanohub/environment.sh
else
  echo -e "${RED}Error: /home/microm/nanohub/environment.sh not found!${NC}"
  exit 1
fi

# Helper functions
print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# MySQL query wrapper
mysql_query() {
    mysql -h "$DB_HOST" -u "$DB_USER" -p"$DB_PASSWORD" "$DB_NAME" -e "$1" 2>/dev/null
}

mysql_query_silent() {
    mysql -h "$DB_HOST" -u "$DB_USER" -p"$DB_PASSWORD" "$DB_NAME" -sN -e "$1" 2>/dev/null
}

# Display help
show_help() {
    cat <<EOF
NanoHUB Device Manager - CRUD Operations

Usage: $0 <command> [options]

Commands:
  search <term>                 - Search devices by hostname, serial, UUID, or OS
  get hostname <hostname>       - Get device by hostname
  get serial <serial>          - Get device by serial number
  get uuid <uuid>              - Get device by UUID
  get os <os>                  - Get all devices by OS (ios/macos)

  add                          - Add new device (interactive prompt)
  update <uuid>                - Update device by UUID (interactive)
  delete <uuid>                - Delete device by UUID (requires confirmation)

  list [ios|macos]             - List all devices or filter by OS
  count [ios|macos]            - Count total devices or by OS

  export                       - Export all devices as JSON
  import <json_file>           - Import devices from JSON file

  stats                        - Show database statistics

Examples:
  $0 search sloto01
  $0 get hostname sloto01
  $0 get serial FVFKQ0LW1WG7
  $0 list ios
  $0 add
  $0 update 1FABE57D-AD95-597F-8E02-E8251E4A1933
  $0 delete 1FABE57D-AD95-597F-8E02-E8251E4A1933
  $0 count
  $0 export > devices_backup.json

EOF
    exit 0
}

# Search devices
search_devices() {
    local search_term="$1"

    if [[ -z "$search_term" ]]; then
        print_error "Search term required"
        exit 1
    fi

    print_info "Searching for: $search_term"

    local sql="SELECT uuid, serial, os, hostname, manifest, account, dep
               FROM device_inventory
               WHERE LOWER(hostname) LIKE LOWER('%${search_term}%')
                  OR LOWER(serial) LIKE LOWER('%${search_term}%')
                  OR LOWER(uuid) LIKE LOWER('%${search_term}%')
                  OR LOWER(os) LIKE LOWER('%${search_term}%')
               ORDER BY hostname"

    mysql_query "$sql"
}

# Get device by specific field
get_device() {
    local field="$1"
    local value="$2"

    if [[ -z "$field" || -z "$value" ]]; then
        print_error "Field and value required"
        exit 1
    fi

    # Validate field
    case "$field" in
        hostname|serial|uuid|os|manifest) ;;
        *) print_error "Invalid field: $field"; exit 1 ;;
    esac

    print_info "Getting device by $field: $value"

    local sql="SELECT uuid, serial, os, hostname, manifest, account, dep
               FROM device_inventory
               WHERE $field='$value'"

    mysql_query "$sql"
}

# Add new device (interactive)
add_device() {
    echo ""
    echo "=== Add New Device ==="
    echo ""

    read -p "UUID: " uuid
    read -p "Serial Number: " serial
    read -p "OS (ios/macos): " os
    read -p "Hostname: " hostname
    read -p "Manifest (default/tech): " manifest
    read -p "Account (enabled/disabled): " account
    read -p "DEP (enabled/disabled): " dep

    # Validate required fields
    if [[ -z "$uuid" || -z "$serial" || -z "$os" || -z "$hostname" ]]; then
        print_error "UUID, Serial, OS, and Hostname are required!"
        exit 1
    fi

    # Set defaults
    [[ -z "$manifest" ]] && manifest="default"
    [[ -z "$account" ]] && account="disabled"
    [[ -z "$dep" ]] && dep="enabled"

    # Validate OS
    if [[ "$os" != "ios" && "$os" != "macos" ]]; then
        print_error "OS must be 'ios' or 'macos'"
        exit 1
    fi

    echo ""
    echo "=== Confirm Device Details ==="
    echo "UUID:      $uuid"
    echo "Serial:    $serial"
    echo "OS:        $os"
    echo "Hostname:  $hostname"
    echo "Manifest:  $manifest"
    echo "Account:   $account"
    echo "DEP:       $dep"
    echo ""

    read -p "Add this device? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        print_warning "Cancelled"
        exit 0
    fi

    local sql="INSERT INTO device_inventory (uuid, serial, os, hostname, manifest, account, dep)
               VALUES ('$uuid', '$serial', '$os', '$hostname', '$manifest', '$account', '$dep')"

    if mysql_query "$sql" 2>/dev/null; then
        print_success "Device added successfully!"
        echo ""
        get_device "uuid" "$uuid"
    else
        print_error "Failed to add device (UUID might already exist)"
        exit 1
    fi
}

# Update device (interactive)
update_device() {
    local uuid="$1"

    if [[ -z "$uuid" ]]; then
        print_error "UUID required"
        exit 1
    fi

    # Check if device exists
    local exists=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE uuid='$uuid'")
    if [[ "$exists" == "0" ]]; then
        print_error "Device not found: $uuid"
        exit 1
    fi

    # Get current values
    local current=$(mysql_query_silent "SELECT serial, os, hostname, manifest, account, dep FROM device_inventory WHERE uuid='$uuid'")
    local current_serial=$(echo "$current" | awk '{print $1}')
    local current_os=$(echo "$current" | awk '{print $2}')
    local current_hostname=$(echo "$current" | awk '{print $3}')
    local current_manifest=$(echo "$current" | awk '{print $4}')
    local current_account=$(echo "$current" | awk '{print $5}')
    local current_dep=$(echo "$current" | awk '{print $6}')

    echo ""
    echo "=== Update Device: $uuid ==="
    echo ""
    echo "Current values:"
    echo "  Serial:   $current_serial"
    echo "  OS:       $current_os"
    echo "  Hostname: $current_hostname"
    echo "  Manifest: $current_manifest"
    echo "  Account:  $current_account"
    echo "  DEP:      $current_dep"
    echo ""
    echo "Enter new values (press Enter to keep current):"
    echo ""

    read -p "Serial [$current_serial]: " serial
    read -p "OS [$current_os]: " os
    read -p "Hostname [$current_hostname]: " hostname
    read -p "Manifest [$current_manifest]: " manifest
    read -p "Account [$current_account]: " account
    read -p "DEP [$current_dep]: " dep

    # Use current values if empty
    [[ -z "$serial" ]] && serial="$current_serial"
    [[ -z "$os" ]] && os="$current_os"
    [[ -z "$hostname" ]] && hostname="$current_hostname"
    [[ -z "$manifest" ]] && manifest="$current_manifest"
    [[ -z "$account" ]] && account="$current_account"
    [[ -z "$dep" ]] && dep="$current_dep"

    echo ""
    read -p "Update device? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        print_warning "Cancelled"
        exit 0
    fi

    local sql="UPDATE device_inventory
               SET serial='$serial', os='$os', hostname='$hostname',
                   manifest='$manifest', account='$account', dep='$dep'
               WHERE uuid='$uuid'"

    if mysql_query "$sql" 2>/dev/null; then
        print_success "Device updated successfully!"
        echo ""
        get_device "uuid" "$uuid"
    else
        print_error "Failed to update device"
        exit 1
    fi
}

# Delete device
delete_device() {
    local uuid="$1"

    if [[ -z "$uuid" ]]; then
        print_error "UUID required"
        exit 1
    fi

    # Check if device exists and show details
    local exists=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE uuid='$uuid'")
    if [[ "$exists" == "0" ]]; then
        print_error "Device not found: $uuid"
        exit 1
    fi

    echo ""
    echo "=== Device to Delete ==="
    get_device "uuid" "$uuid"
    echo ""

    print_warning "This action CANNOT be undone!"
    read -p "Are you sure you want to delete this device? (yes/N): " confirm

    if [[ "$confirm" != "yes" ]]; then
        print_warning "Cancelled (must type 'yes' to confirm)"
        exit 0
    fi

    local sql="DELETE FROM device_inventory WHERE uuid='$uuid'"

    if mysql_query "$sql" 2>/dev/null; then
        print_success "Device deleted successfully!"
    else
        print_error "Failed to delete device"
        exit 1
    fi
}

# List devices
list_devices() {
    local os_filter="$1"

    if [[ -n "$os_filter" ]]; then
        if [[ "$os_filter" != "ios" && "$os_filter" != "macos" ]]; then
            print_error "OS filter must be 'ios' or 'macos'"
            exit 1
        fi
        print_info "Listing $os_filter devices"
        local sql="SELECT uuid, serial, os, hostname, manifest, account, dep
                   FROM device_inventory
                   WHERE os='$os_filter'
                   ORDER BY hostname"
    else
        print_info "Listing all devices"
        local sql="SELECT uuid, serial, os, hostname, manifest, account, dep
                   FROM device_inventory
                   ORDER BY hostname"
    fi

    mysql_query "$sql"
}

# Count devices
count_devices() {
    local os_filter="$1"

    if [[ -n "$os_filter" ]]; then
        if [[ "$os_filter" != "ios" && "$os_filter" != "macos" ]]; then
            print_error "OS filter must be 'ios' or 'macos'"
            exit 1
        fi
        local count=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE os='$os_filter'")
        echo "$os_filter devices: $count"
    else
        local total=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory")
        local ios_count=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE os='ios'")
        local macos_count=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE os='macos'")

        echo "Total devices: $total"
        echo "  iOS:   $ios_count"
        echo "  macOS: $macos_count"
    fi
}

# Export devices as JSON
export_devices() {
    print_info "Exporting all devices as JSON"

    local sql="SELECT JSON_ARRAYAGG(
                   JSON_OBJECT(
                       'uuid', uuid,
                       'serial', serial,
                       'os', os,
                       'hostname', hostname,
                       'manifest', manifest,
                       'account', account,
                       'dep', dep
                   )
               ) FROM device_inventory"

    mysql_query_silent "$sql" | python3 -m json.tool
}

# Import devices from JSON file
import_devices() {
    local json_file="$1"

    if [[ ! -f "$json_file" ]]; then
        print_error "File not found: $json_file"
        exit 1
    fi

    print_info "Importing devices from: $json_file"

    # Validate JSON
    if ! jq empty "$json_file" 2>/dev/null; then
        print_error "Invalid JSON file"
        exit 1
    fi

    local device_count=$(jq 'length' "$json_file")
    print_info "Found $device_count devices to import"

    echo ""
    read -p "Import all devices? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        print_warning "Cancelled"
        exit 0
    fi

    local success=0
    local failed=0
    local skipped=0

    while IFS= read -r device; do
        local uuid=$(echo "$device" | jq -r '.uuid')
        local serial=$(echo "$device" | jq -r '.serial')
        local os=$(echo "$device" | jq -r '.os')
        local hostname=$(echo "$device" | jq -r '.hostname')
        local manifest=$(echo "$device" | jq -r '.manifest // "default"')
        local account=$(echo "$device" | jq -r '.account // "disabled"')
        local dep=$(echo "$device" | jq -r '.dep // "enabled"')

        # Check if device already exists
        local exists=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE uuid='$uuid'")
        if [[ "$exists" != "0" ]]; then
            print_warning "Device already exists, skipping: $hostname ($uuid)"
            ((skipped++))
            continue
        fi

        local sql="INSERT INTO device_inventory (uuid, serial, os, hostname, manifest, account, dep)
                   VALUES ('$uuid', '$serial', '$os', '$hostname', '$manifest', '$account', '$dep')"

        if mysql_query "$sql" 2>/dev/null; then
            print_success "Imported: $hostname ($uuid)"
            ((success++))
        else
            print_error "Failed to import: $hostname ($uuid)"
            ((failed++))
        fi
    done < <(jq -c '.[]' "$json_file")

    echo ""
    echo "=== Import Summary ==="
    echo "Success: $success"
    echo "Failed:  $failed"
    echo "Skipped: $skipped"
}

# Show statistics
show_stats() {
    echo ""
    echo "=== Device Inventory Statistics ==="
    echo ""

    local total=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory")
    local ios_count=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE os='ios'")
    local macos_count=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE os='macos'")
    local default_manifest=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE manifest='default'")
    local tech_manifest=$(mysql_query_silent "SELECT COUNT(*) FROM device_inventory WHERE manifest='tech'")

    echo "Total Devices: $total"
    echo "iOS: $ios_count"
    echo "macOS: $macos_count"
    echo ""
    echo "Manifests:"
    echo "  default: $default_manifest"
    echo "  tech: $tech_manifest"
    echo ""

    # Most common manifests
    echo "Device breakdown by manifest:"
    mysql_query_silent "SELECT manifest, COUNT(*) as count FROM device_inventory GROUP BY manifest ORDER BY count DESC" | while read -r manifest count; do
        echo "  $manifest: $count"
    done
}

# Main command dispatcher
if [[ $# -eq 0 ]]; then
    show_help
fi

COMMAND="$1"
shift

case "$COMMAND" in
    search)
        search_devices "$@"
        ;;
    get)
        get_device "$@"
        ;;
    add)
        add_device
        ;;
    update)
        update_device "$@"
        ;;
    delete)
        delete_device "$@"
        ;;
    list)
        list_devices "$@"
        ;;
    count)
        count_devices "$@"
        ;;
    export)
        export_devices
        ;;
    import)
        import_devices "$@"
        ;;
    stats)
        show_stats
        ;;
    -h|--help|help)
        show_help
        ;;
    *)
        print_error "Unknown command: $COMMAND"
        echo ""
        show_help
        ;;
esac
